---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';
import yaml from 'yaml';

export function getStaticPaths() {
  const registryPath = path.resolve('../registry.yaml');
  if (!fs.existsSync(registryPath)) {
    throw new Error(`Registry file not found at ${registryPath}. This may happen if the file was manually deleted or if copy-registry failed. Try running 'npm run copy-registry' manually.`);
  }
  const registryContent = fs.readFileSync(registryPath, 'utf-8');
  const registry = yaml.parse(registryContent);
  
  return registry.skills.map((skill: any) => {
    const skillMdPath = path.resolve('../' + skill.path, 'SKILL.md');
    let skillMdContent = '';
    if (fs.existsSync(skillMdPath)) {
      skillMdContent = fs.readFileSync(skillMdPath, 'utf-8');
    } else {
      console.warn(`SKILL.md not found at ${skillMdPath}`);
    }
    
    return {
      params: { slug: `skill/${skill.name}` },
      props: { skill, skillMdContent },
    };
  });
}

interface Props {
  skill: any;
  skillMdContent: string;
}

const { skill, skillMdContent } = Astro.props;
---

<Layout title={skill.title}>
  <style>
    :root {
      --primary: #00d4ff;
      --secondary: #7c3aed;
      --accent: #10b981;
      --dark: #0f172a;
      --darker: #020617;
      --card: #1e293b;
      --text: #e2e8f0;
      --muted: #94a3b8;
      --border: #334155;
    }

    .page-wrapper {
      max-width: 1400px;
      margin: 0 auto;
      padding: 60px 24px;
    }

    .skill-detail {
      max-width: 900px;
      margin: 0 auto;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 32px;
      color: var(--muted);
      text-decoration: none;
      font-weight: 600;
      font-size: 14px;
      transition: all 0.2s;
    }

    .back-link:hover {
      color: var(--primary);
      transform: translateX(-4px);
    }

    .skill-header {
      margin-bottom: 40px;
      padding-bottom: 32px;
      border-bottom: 1px solid var(--border);
    }

    .skill-header h1 {
      font-size: 40px;
      font-weight: 800;
      background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 12px;
      font-family: 'SF Mono', 'Fira Code', monospace;
    }

    .skill-meta {
      color: var(--muted);
      margin-bottom: 16px;
      font-size: 16px;
    }

    .skill-tags {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .tag {
      background: rgba(0, 212, 255, 0.12);
      color: var(--primary);
      padding: 6px 14px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      border: 1px solid rgba(0, 212, 255, 0.2);
    }

    .install-section {
      background: linear-gradient(135deg, rgba(0, 212, 255, 0.1) 0%, rgba(124, 58, 237, 0.1) 100%);
      border: 1px solid rgba(0, 212, 255, 0.2);
      padding: 32px;
      border-radius: 16px;
      margin-bottom: 32px;
      backdrop-filter: blur(10px);
    }

    .install-section h3 {
      color: var(--text);
      margin-bottom: 12px;
      font-weight: 700;
      font-size: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .install-section p {
      color: var(--muted);
      margin-bottom: 20px;
      line-height: 1.6;
      font-size: 15px;
    }

    .code-blocks {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .code-block {
      background: rgba(15, 23, 42, 0.8);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 15px;
    }

    .code-text {
      color: var(--primary);
    }

    .copy-btn {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--muted);
      padding: 8px 16px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 600;
      transition: all 0.2s;
    }

    .copy-btn:hover {
      border-color: var(--primary);
      color: var(--primary);
    }

    .skill-content {
      background: rgba(30, 41, 59, 0.6);
      border: 1px solid var(--border);
      padding: 32px;
      border-radius: 16px;
    }

    .skill-content h3 {
      color: var(--text);
      margin-bottom: 20px;
      font-weight: 700;
      font-size: 20px;
    }

    .skill-content pre {
      background: rgba(15, 23, 42, 0.9);
      color: var(--text);
      padding: 24px;
      border-radius: 12px;
      overflow-x: auto;
      font-size: 14px;
      line-height: 1.8;
      border: 1px solid var(--border);
      white-space: pre-wrap;
      word-wrap: break-word;
    }

    .skill-content code {
      font-family: 'SF Mono', 'Fira Code', monospace;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .page-wrapper {
        padding: 40px 16px;
      }

      .skill-header h1 {
        font-size: 28px;
      }

      .install-section {
        padding: 24px;
      }

      .skill-content {
        padding: 24px;
      }
    }
  </style>

  <div class="page-wrapper">
    <a href="/" class="back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Back to Home
    </a>

    <div class="skill-detail">
      <div class="skill-header">
        <h1>{skill.name}</h1>
        <p class="skill-meta">{skill.title} · v{skill.version} · {skill.domain.toUpperCase()}</p>
        <div class="skill-tags">
          {skill.tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
      </div>

      <div class="install-section">
        <h3>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--primary);">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
          Install & Read
        </h3>
        <p>
          Skills are for AI Agents to read and execute, not for direct human execution.
        </p>
        <div class="code-blocks">
          <div class="code-block">
            <span class="code-text">$ skill install {skill.name}</span>
            <button class="copy-btn" onclick="navigator.clipboard.writeText('skill install {skill.name}')">Copy</button>
          </div>
          <div class="code-block">
            <span class="code-text">$ skill read {skill.name}</span>
            <button class="copy-btn" onclick="navigator.clipboard.writeText('skill read {skill.name}')">Copy</button>
          </div>
        </div>
      </div>

      <div class="skill-content">
        <h3>Skill Content</h3>
        <pre>{skillMdContent}</pre>
      </div>
    </div>
  </div>
</Layout>
