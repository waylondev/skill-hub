---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';
import yaml from 'yaml';

export function getStaticPaths() {
  const registryPath = path.resolve('./registry.yaml');
  if (!fs.existsSync(registryPath)) {
    throw new Error(`Registry file not found at ${registryPath}. This may happen if the file was manually deleted or if copy-registry failed. Try running 'npm run copy-registry' manually.`);
  }
  const registryContent = fs.readFileSync(registryPath, 'utf-8');
  const registry = yaml.parse(registryContent);
  
  return registry.skills.map((skill: any) => {
    const skillMdPath = path.resolve('../../' + skill.path, 'SKILL.md');
    let skillMdContent = '';
    if (fs.existsSync(skillMdPath)) {
      skillMdContent = fs.readFileSync(skillMdPath, 'utf-8');
    }
    
    return {
      params: { slug: `skill/${skill.name}` },
      props: { skill, skillMdContent },
    };
  });
}

interface Props {
  skill: any;
  skillMdContent: string;
}

const { skill, skillMdContent } = Astro.props;
---

<Layout title={skill.title}>
  <style>
    .skill-detail { max-width: 900px; }
    .skill-header { margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 2px solid #e0e0e0; }
    .skill-header h1 { font-size: 2.5rem; margin-bottom: 0.5rem; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-weight: 700; }
    .skill-meta { color: #718096; margin-bottom: 1rem; font-size: 1.1rem; }
    .skill-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
    .tag { background: linear-gradient(135deg, #e0e7ff 0%, #f0f4ff 100%); color: #4338ca; padding: 0.35rem 0.75rem; border-radius: 6px; font-size: 0.9rem; font-weight: 500; border: 1px solid rgba(67, 56, 202, 0.1); }
    .install-section { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 2rem; border-radius: 12px; margin-bottom: 2rem; box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3); color: white; }
    .install-section h3 { color: white; margin-bottom: 1rem; font-weight: 600; }
    .install-section p { opacity: 0.95; margin-bottom: 1.5rem; line-height: 1.6; }
    .code-block { background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(10px); color: white; padding: 1rem; border-radius: 8px; font-family: 'Courier New', monospace; margin: 0.5rem 0; display: flex; justify-content: space-between; align-items: center; border: 1px solid rgba(255, 255, 255, 0.2); }
    .copy-btn { background: rgba(255, 255, 255, 0.2); color: white; border: 1px solid rgba(255, 255, 255, 0.3); padding: 0.5rem 1rem; border-radius: 4px; cursor: pointer; transition: all 0.2s; font-size: 0.9rem; }
    .copy-btn:hover { background: rgba(255, 255, 255, 0.3); transform: translateY(-1px); }
    .skill-content { background: #f9f9f9; padding: 2rem; border-radius: 12px; border: 1px solid #e0e0e0; }
    .skill-content h3 { color: #2d3748; margin-bottom: 1rem; font-weight: 600; }
    .skill-content pre { background: #1a1a2e; color: #e0e0e0; padding: 1.5rem; border-radius: 8px; overflow-x: auto; font-size: 0.9rem; line-height: 1.6; }
    .skill-content code { font-family: 'Courier New', monospace; }
    .back-link { display: inline-block; margin-bottom: 2rem; color: #667eea; text-decoration: none; font-weight: 500; transition: all 0.2s; }
    .back-link:hover { color: #764ba2; transform: translateX(-4px); }
  </style>

  <a href="/" class="back-link">← Back to Home</a>

  <div class="skill-detail">
    <div class="skill-header">
      <h1>{skill.name}</h1>
      <p class="skill-meta">{skill.title} · v{skill.version} · {skill.domain.toUpperCase()}</p>
      <div class="skill-tags">
        {skill.tags.map((tag: string) => <span class="tag">{tag}</span>)}
      </div>
    </div>

    <div class="install-section">
      <h3>Install & Read</h3>
      <p style="color: #e0e0e0; margin-bottom: 1rem; font-size: 0.9rem;">
        Skills are for AI Agents to read and execute, not for direct human execution.
      </p>
      <div class="code-block">
        <span>$ skill install {skill.name}</span>
        <button class="copy-btn" onclick="navigator.clipboard.writeText('skill install {skill.name}')">Copy</button>
      </div>
      <div class="code-block">
        <span>$ skill read {skill.name}</span>
        <button class="copy-btn" onclick="navigator.clipboard.writeText('skill read {skill.name}')">Copy</button>
      </div>
    </div>

    <div class="skill-content">
      <h3>Skill Content</h3>
      <pre>{skillMdContent}</pre>
    </div>
  </div>
</Layout>
