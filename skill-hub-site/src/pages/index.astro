---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';
import yaml from 'yaml';

const registryPath = path.resolve('./registry.yaml');
if (!fs.existsSync(registryPath)) {
  throw new Error(`Registry file not found at ${registryPath}. This may happen if the file was manually deleted or if copy-registry failed. Try running 'npm run copy-registry' manually.`);
}
const registryContent = fs.readFileSync(registryPath, 'utf-8');
const registry = yaml.parse(registryContent);

const skills = registry.skills;

// Group by domain
const skillsByDomain: Record<string, any[]> = {};
for (const skill of skills) {
  if (!skillsByDomain[skill.domain]) {
    skillsByDomain[skill.domain] = [];
  }
  skillsByDomain[skill.domain].push(skill);
}
---

<Layout title="Home">
  <style>
    .search-section { margin-bottom: 3rem; }
    .search-input { width: 100%; padding: 1rem; font-size: 1.1rem; border: 2px solid #e0e0e0; border-radius: 8px; transition: all 0.3s; }
    .search-input:focus { border-color: #667eea; outline: none; box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1); }
    .quick-start { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 2.5rem; border-radius: 12px; margin-bottom: 3rem; color: white; box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3); }
    .quick-start h2 { margin-bottom: 1rem; color: white; font-weight: 600; }
    .quick-start p { opacity: 0.95; line-height: 1.6; }
    .code-block { background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(10px); color: white; padding: 1rem; border-radius: 8px; font-family: 'Courier New', monospace; margin: 0.5rem 0; display: flex; justify-content: space-between; align-items: center; border: 1px solid rgba(255, 255, 255, 0.2); }
    .copy-btn { background: rgba(255, 255, 255, 0.2); color: white; border: 1px solid rgba(255, 255, 255, 0.3); padding: 0.5rem 1rem; border-radius: 4px; cursor: pointer; transition: all 0.2s; font-size: 0.9rem; }
    .copy-btn:hover { background: rgba(255, 255, 255, 0.3); transform: translateY(-1px); }
    .domain-section { margin-bottom: 2.5rem; }
    .domain-title { font-size: 1.4rem; margin-bottom: 1rem; color: #764ba2; font-weight: 600; display: flex; align-items: center; gap: 0.5rem; }
    .domain-title::before { content: ''; display: inline-block; width: 4px; height: 24px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 2px; }
    .skill-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.25rem; }
    .skill-card { border: 1px solid #e0e0e0; border-radius: 12px; padding: 1.5rem; transition: all 0.3s; background: white; position: relative; overflow: hidden; }
    .skill-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #667eea 0%, #764ba2 100%); transform: scaleX(0); transition: transform 0.3s; }
    .skill-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.12); transform: translateY(-2px); }
    .skill-card:hover::before { transform: scaleX(1); }
    .skill-name { font-weight: 600; font-size: 1.1rem; margin-bottom: 0.5rem; color: #2d3748; font-family: 'Courier New', monospace; }
    .skill-title { color: #718096; margin-bottom: 0.75rem; line-height: 1.5; }
    .skill-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .tag { background: linear-gradient(135deg, #e0e7ff 0%, #f0f4ff 100%); color: #4338ca; padding: 0.35rem 0.75rem; border-radius: 6px; font-size: 0.85rem; font-weight: 500; border: 1px solid rgba(67, 56, 202, 0.1); transition: all 0.2s; }
    .tag:hover { background: #e0e7ff; transform: translateY(-1px); }
    .top-skills { margin-bottom: 3rem; }
    .top-skills h2 { margin-bottom: 1.5rem; font-weight: 600; color: #2d3748; }
    .hero-section { text-align: center; padding: 3rem 0; margin-bottom: 2rem; }
    .hero-section h1 { font-size: 2.5rem; margin-bottom: 1rem; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-weight: 700; }
    .hero-section p { font-size: 1.2rem; color: #718096; max-width: 600px; margin: 0 auto; line-height: 1.8; }
  </style>

  <section class="quick-start">
    <h2>Turn Knowledge into AI Execution</h2>
    <p style="margin-bottom: 1rem; color: #666;">
      Capture reusable operational knowledge from Confluence, wikis, SOPs, and tribal knowledge. 
      Let AI Agents execute repetitive tasks for you.
    </p>
    <div class="code-block">
      <span>$ skill install sn-request-software</span>
      <button class="copy-btn" onclick="navigator.clipboard.writeText('skill install sn-request-software')">Copy</button>
    </div>
    <div class="code-block">
        <span>$ skill read sn-request-software</span>
        <button class="copy-btn" onclick="navigator.clipboard.writeText('skill read sn-request-software')">Copy</button>
      </div>
  </section>

  <section class="search-section">
    <input type="text" class="search-input" id="searchInput" placeholder="Search Skills..." />
  </section>

  <section class="top-skills">
    <h2>Top Skills</h2>
    <div class="skill-grid">
      {skills.slice(0, 5).map((skill, index) => (
        <div class="skill-card">
          <div style="font-size: 1.5rem; margin-bottom: 0.5rem;">{['🥇', '🥈', '🥉', '4️⃣', '5️⃣'][index]}</div>
          <div class="skill-name">{skill.name}</div>
          <div class="skill-title">{skill.title}</div>
          <div class="skill-tags">
            {skill.tags.map((tag: string) => <span class="tag">{tag}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>

  {Object.entries(skillsByDomain).map(([domain, domainSkills]) => (
    <section class="domain-section">
      <h2 class="domain-title">{domain.toUpperCase()} ({domainSkills.length})</h2>
      <div class="skill-grid">
        {domainSkills.map((skill) => (
          <a href={`/skill/${skill.name}`} style="text-decoration: none; color: inherit;">
            <div class="skill-card">
              <div class="skill-name">{skill.name}</div>
              <div class="skill-title">{skill.title}</div>
              <div class="skill-tags">
                {skill.tags.map((tag: string) => <span class="tag">{tag}</span>)}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  ))}

  <script>
    const searchInput = document.getElementById('searchInput');
    const cards = document.querySelectorAll('.skill-card');
    
    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      cards.forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = text.includes(query) ? 'block' : 'none';
      });
    });
  </script>
</Layout>
