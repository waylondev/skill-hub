---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';
import yaml from 'yaml';

const registryPath = path.resolve('./registry.yaml');
if (!fs.existsSync(registryPath)) {
  throw new Error(`Registry file not found at ${registryPath}. This may happen if the file was manually deleted or if copy-registry failed. Try running 'npm run copy-registry' manually.`);
}
const registryContent = fs.readFileSync(registryPath, 'utf-8');
const registry = yaml.parse(registryContent);

const skills = registry.skills;

// Group by domain
const skillsByDomain: Record<string, any[]> = {};
for (const skill of skills) {
  if (!skillsByDomain[skill.domain]) {
    skillsByDomain[skill.domain] = [];
  }
  skillsByDomain[skill.domain].push(skill);
}

// Domain colors for visual distinction
const domainColors: Record<string, { primary: string; gradient: string }> = {
  env: { primary: '#00d4ff', gradient: 'linear-gradient(135deg, #00d4ff, #0099cc)' },
  sn: { primary: '#10b981', gradient: 'linear-gradient(135deg, #10b981, #059669)' },
  swc: { primary: '#f59e0b', gradient: 'linear-gradient(135deg, #f59e0b, #d97706)' },
  web: { primary: '#ec4899', gradient: 'linear-gradient(135deg, #ec4899, #db2777)' },
  dev: { primary: '#8b5cf6', gradient: 'linear-gradient(135deg, #8b5cf6, #7c3aed)' }
};
---

<Layout title="Home">
  <style>
    :root {
      --primary: #00d4ff;
      --secondary: #7c3aed;
      --accent: #10b981;
      --dark: #0f172a;
      --darker: #020617;
      --card: #1e293b;
      --text: #e2e8f0;
      --muted: #94a3b8;
      --border: #334155;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, var(--darker) 0%, var(--dark) 100%);
      color: var(--text);
      line-height: 1.6;
      min-height: 100vh;
      overflow-x: hidden;
    }

    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .hero {
      text-align: center;
      padding: 120px 0 80px;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(0, 212, 255, 0.12) 0%, transparent 60%);
      animation: pulse 8s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 0.6; }
      50% { transform: scale(1.05); opacity: 0.8; }
    }

    .hero::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(0, 212, 255, 0.3), transparent);
    }

    .hero-content {
      position: relative;
      z-index: 1;
    }

    .logo {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-size: 14px;
      font-weight: 700;
      color: var(--primary);
      letter-spacing: 4px;
      text-transform: uppercase;
      margin-bottom: 32px;
      padding: 10px 24px;
      background: rgba(0, 212, 255, 0.08);
      border: 1px solid rgba(0, 212, 255, 0.2);
      border-radius: 100px;
      backdrop-filter: blur(10px);
    }

    .hero h1 {
      font-size: clamp(40px, 8vw, 72px);
      font-weight: 800;
      background: linear-gradient(135deg, #ffffff 0%, var(--primary) 50%, var(--secondary) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 28px;
      line-height: 1.1;
      letter-spacing: -2px;
    }

    .hero-subtitle {
      font-size: clamp(18px, 2.5vw, 24px);
      color: var(--text);
      max-width: 900px;
      margin: 0 auto 56px;
      font-weight: 400;
      opacity: 0.85;
      line-height: 1.7;
    }

    .value-props {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 28px;
      max-width: 1200px;
      margin: 0 auto 96px;
    }

    .value-prop {
      background: linear-gradient(135deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.6) 100%);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 36px;
      text-align: left;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
    }

    .value-prop::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--primary), transparent);
      opacity: 0;
      transition: opacity 0.3s;
    }

    .value-prop:hover {
      border-color: rgba(0, 212, 255, 0.4);
      transform: translateY(-8px);
      box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(0, 212, 255, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .value-prop:hover::before {
      opacity: 1;
    }

    .value-prop-icon {
      font-size: 44px;
      margin-bottom: 20px;
    }

    .value-prop-title {
      font-size: 22px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 14px;
      letter-spacing: -0.5px;
    }

    .value-prop-desc {
      font-size: 15px;
      color: var(--muted);
      line-height: 1.7;
    }

    .stats {
      display: flex;
      justify-content: center;
      gap: 96px;
      margin-bottom: 96px;
      flex-wrap: wrap;
    }

    .stat {
      text-align: center;
    }

    .stat-number {
      font-size: clamp(48px, 6vw, 64px);
      font-weight: 800;
      background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      display: block;
      letter-spacing: -2px;
    }

    .stat-label {
      font-size: 13px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 3px;
      margin-top: 12px;
      font-weight: 600;
    }

    .quick-start {
      background: linear-gradient(135deg, rgba(0, 212, 255, 0.06) 0%, rgba(124, 58, 237, 0.06) 100%);
      border: 1px solid rgba(0, 212, 255, 0.15);
      border-radius: 20px;
      padding: 48px;
      margin-bottom: 56px;
      backdrop-filter: blur(20px);
      position: relative;
      overflow: hidden;
    }

    .quick-start::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(0, 212, 255, 0.5), transparent);
    }

    .quick-start-header {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 32px;
    }

    .quick-start-title {
      font-size: 26px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.5px;
    }

    .code-blocks {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .code-block {
      background: rgba(15, 23, 42, 0.9);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px 28px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 16px;
      transition: all 0.3s;
    }

    .code-block:hover {
      border-color: rgba(0, 212, 255, 0.3);
      background: rgba(15, 23, 42, 1);
    }

    .code-text {
      color: var(--primary);
      font-weight: 500;
    }

    .copy-btn {
      background: rgba(0, 212, 255, 0.1);
      border: 1px solid rgba(0, 212, 255, 0.3);
      color: var(--primary);
      padding: 10px 20px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 600;
      transition: all 0.3s;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .copy-btn:hover {
      background: rgba(0, 212, 255, 0.2);
      border-color: var(--primary);
      box-shadow: 0 0 20px rgba(0, 212, 255, 0.2);
    }

    .search-section {
      margin-bottom: 64px;
    }

    .search-wrapper {
      position: relative;
    }

    .search-icon {
      position: absolute;
      left: 28px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
      font-size: 22px;
      pointer-events: none;
    }

    .search-input {
      width: 100%;
      padding: 24px 24px 24px 72px;
      font-size: 18px;
      background: rgba(30, 41, 59, 0.6);
      border: 2px solid var(--border);
      border-radius: 16px;
      color: var(--text);
      transition: all 0.3s;
      font-weight: 400;
    }

    .search-input:focus {
      outline: none;
      border-color: var(--primary);
      box-shadow: 0 0 0 4px rgba(0, 212, 255, 0.1), 0 8px 32px rgba(0, 0, 0, 0.3);
      background: rgba(30, 41, 59, 0.9);
    }

    .search-input::placeholder {
      color: var(--muted);
    }

    .domain-section {
      margin-bottom: 64px;
    }

    .domain-header {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 32px;
    }

    .domain-indicator {
      width: 6px;
      height: 32px;
      border-radius: 3px;
      box-shadow: 0 0 20px currentColor;
    }

    .domain-title {
      font-size: 26px;
      font-weight: 800;
      color: var(--text);
      text-transform: uppercase;
      letter-spacing: 2px;
      flex: 1;
    }

    .domain-count {
      background: rgba(0, 212, 255, 0.12);
      color: var(--primary);
      padding: 8px 18px;
      border-radius: 100px;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.5px;
    }

    .skill-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
      gap: 28px;
    }

    .skill-card {
      background: linear-gradient(135deg, rgba(30, 41, 59, 0.7) 0%, rgba(15, 23, 42, 0.5) 100%);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 32px;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      cursor: pointer;
      position: relative;
      overflow: hidden;
    }

    .skill-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: var(--card-gradient, linear-gradient(90deg, var(--primary), var(--secondary)));
      transform: scaleX(0);
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      transform-origin: left;
    }

    .skill-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 50% 0%, rgba(0, 212, 255, 0.08) 0%, transparent 60%);
      opacity: 0;
      transition: opacity 0.3s;
    }

    .skill-card:hover {
      border-color: rgba(0, 212, 255, 0.35);
      transform: translateY(-8px) scale(1.02);
      box-shadow: 0 28px 56px rgba(0, 0, 0, 0.45), 0 0 0 1px rgba(0, 212, 255, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .skill-card:hover::before {
      transform: scaleX(1);
    }

    .skill-card:hover::after {
      opacity: 1;
    }

    .skill-content {
      position: relative;
      z-index: 1;
    }

    .skill-name {
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 17px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 12px;
      letter-spacing: -0.3px;
    }

    .skill-desc {
      font-size: 15px;
      color: var(--muted);
      line-height: 1.65;
      margin-bottom: 20px;
    }

    .skill-tags {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .tag {
      background: rgba(0, 212, 255, 0.1);
      color: var(--tag-color, var(--primary));
      padding: 6px 14px;
      border-radius: 8px;
      font-size: 12px;
      font-weight: 600;
      border: 1px solid rgba(0, 212, 255, 0.15);
      letter-spacing: 0.3px;
    }

    @media (max-width: 1024px) {
      .value-props {
        grid-template-columns: 1fr;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
      }
      
      .stats {
        gap: 48px;
      }
    }

    @media (max-width: 768px) {
      .hero {
        padding: 80px 0 60px;
      }
      
      .hero h1 {
        letter-spacing: -1px;
      }
      
      .hero-subtitle {
        font-size: 17px;
        margin-bottom: 40px;
      }
      
      .stats {
        flex-direction: column;
        gap: 32px;
        margin-bottom: 64px;
      }
      
      .stat-number {
        font-size: 48px;
      }
      
      .skill-grid {
        grid-template-columns: 1fr;
      }
      
      .quick-start {
        padding: 32px 24px;
      }
      
      .domain-header {
        flex-wrap: wrap;
      }
    }

    html {
      scroll-behavior: smooth;
    }

    ::selection {
      background: rgba(0, 212, 255, 0.3);
      color: white;
    }
  </style>

  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="logo">✦ SKILL-HUB</div>
        <h1>Turn Knowledge into AI Execution</h1>
        <p class="hero-subtitle">
          Capture reusable operational knowledge from Confluence, wikis, SOPs, and tribal knowledge.
          Let AI Agents execute repetitive tasks for you.
        </p>

        <div class="value-props">
          <div class="value-prop">
            <div class="value-prop-icon">📚</div>
            <h3 class="value-prop-title">Capture Knowledge</h3>
            <p class="value-prop-desc">Transform documentation, SOPs, and tribal knowledge into AI-executable Skills</p>
          </div>
          <div class="value-prop">
            <div class="value-prop-icon">🤖</div>
            <h3 class="value-prop-title">AI Execution</h3>
            <p class="value-prop-desc">Let AI Agents understand and execute your operational workflows automatically</p>
          </div>
          <div class="value-prop">
            <div class="value-prop-icon">⚡</div>
            <h3 class="value-prop-title">Reusable Skills</h3>
            <p class="value-prop-desc">Build a library of Skills that can be shared and reused across your organization</p>
          </div>
        </div>

        <div class="stats">
          <div class="stat">
            <span class="stat-number">{skills.length}</span>
            <span class="stat-label">Skills Available</span>
          </div>
          <div class="stat">
            <span class="stat-number">{Object.keys(skillsByDomain).length}</span>
            <span class="stat-label">Domains Covered</span>
          </div>
          <div class="stat">
            <span class="stat-number">∞</span>
            <span class="stat-label">Possibilities</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <section class="quick-start">
      <div class="quick-start-header">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--primary);">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
        </svg>
        <h2 class="quick-start-title">Get Started in Seconds</h2>
      </div>
      <div class="code-blocks">
        <div class="code-block">
          <span class="code-text">$ skill install sn-request-software</span>
          <button class="copy-btn" onclick="navigator.clipboard.writeText('skill install sn-request-software')">Copy</button>
        </div>
        <div class="code-block">
          <span class="code-text">$ skill read sn-request-software</span>
          <button class="copy-btn" onclick="navigator.clipboard.writeText('skill read sn-request-software')">Copy</button>
        </div>
      </div>
    </section>

    <section class="search-section">
      <div class="search-wrapper">
        <span class="search-icon">🔍</span>
        <input type="text" class="search-input" id="searchInput" placeholder="Search Skills by name, description, or tags..." />
      </div>
    </section>

    {Object.entries(skillsByDomain).map(([domain, domainSkills]) => (
      <section class="domain-section">
        <div class="domain-header">
          <div class="domain-indicator" style={`background: ${domainColors[domain]?.gradient || 'var(--primary)'}; color: ${domainColors[domain]?.primary || 'var(--primary)'};`}></div>
          <h2 class="domain-title">{domain}</h2>
          <span class="domain-count">{domainSkills.length} Skills</span>
        </div>
        <div class="skill-grid">
          {domainSkills.map((skill) => (
            <a href={`skill/${skill.name}`} style="text-decoration: none; color: inherit;">
              <div class="skill-card" style={`--card-gradient: ${domainColors[domain]?.gradient || 'var(--primary)'};`}>
                <div class="skill-content">
                  <div class="skill-name">{skill.name}</div>
                  <div class="skill-desc">{skill.title}</div>
                  <div class="skill-tags">
                    {skill.tags.slice(0, 3).map((tag: string) => <span class="tag" style={`--tag-color: ${domainColors[domain]?.primary || 'var(--primary)'};`}>{tag}</span>)}
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>

  <script>
    const searchInput = document.getElementById('searchInput');
    const cards = document.querySelectorAll('.skill-card');
    const sections = document.querySelectorAll('.domain-section');

    searchInput?.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase().trim();
      
      cards.forEach(card => {
        const text = card.textContent.toLowerCase();
        const shouldShow = !query || text.includes(query);
        
        if (!shouldShow && card.style.display !== 'none') {
          card.style.opacity = '0';
          card.style.transform = 'scale(0.95)';
          setTimeout(() => {
            card.style.display = 'none';
          }, 150);
        } else if (shouldShow && card.style.display === 'none') {
          card.style.display = '';
          setTimeout(() => {
            card.style.opacity = '1';
            card.style.transform = 'scale(1)';
          }, 10);
        } else {
          card.style.display = shouldShow ? '' : 'none';
          card.style.opacity = shouldShow ? '1' : '0';
          card.style.transform = shouldShow ? 'scale(1)' : 'scale(0.95)';
        }
      });

      sections.forEach(section => {
        const visibleCards = section.querySelectorAll('.skill-card[style*="display: none"]');
        const totalCards = section.querySelectorAll('.skill-card');
        section.style.display = visibleCards.length === totalCards.length && query ? 'none' : '';
      });
    });
  </script>
</Layout>
